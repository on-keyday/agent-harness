
config.go.package = "appwire"


# Harness application payload kinds. They ride the same leading wire byte as the
# shared transport wire.ApplicationPayloadKind, but live in the reserved app
# range (>= 0x40) so they never collide with transport kinds (0x00-0x3F). The
# shared trsf core handles transport kinds and routes everything else (these) to
# the application control layer.
enum AppKind:
    :u8
    pubsub = 0x40
    task_control = 0x41
    relay_control = 0x42
    runner_control = 0x43
    agent_message = 0x44
    psk_auth = 0x45
    agent_proxy_control = 0x46
    dial_greeting = 0x47
