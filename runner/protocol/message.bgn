config.go.package = "protocol"

enum RunnerMessageType:
    :u8
    hello
    task_accepted
    task_started
    task_finished
    heartbeat

enum RunnerRequestType:
    :u8
    assign_task
    cancel_task
    open_exec

format RunnerHello:
    version :u8
    repo_path_len :u16
    repo_path :[repo_path_len]u8

format TaskID:
    id :[16]u8

format AssignTask:
    task_id :TaskID
    prompt :[..]u8

format CancelTask:
    task_id :TaskID

format OpenExecRunnerRequest:
    task_id :TaskID
    stream_id :u64    # bidi stream the server has just created toward this
                      # runner; runner looks it up via
                      # Transport.GetBidirectionalStream(id) and feeds it to
                      # exec.ExecuteCommand for an interactive PTY claude.

format TaskAccepted:
    task_id :TaskID

format TaskStarted:
    task_id :TaskID
    worktree_dir_len :u16
    worktree_dir :[worktree_dir_len]u8

format TaskFinished:
    task_id :TaskID
    exit_code :i32
    diff_info :[..]u8

format RunnerMessage:
    kind :RunnerMessageType
    match kind:
        RunnerMessageType.hello => hello :RunnerHello
        RunnerMessageType.task_accepted => task_accepted :TaskAccepted
        RunnerMessageType.task_started => task_started :TaskStarted
        RunnerMessageType.task_finished => task_finished :TaskFinished
        RunnerMessageType.heartbeat => ..
        .. => error("Unexpected message")

format RunnerRequest:
    kind :RunnerRequestType
    match kind:
        RunnerRequestType.assign_task => assign_task :AssignTask
        RunnerRequestType.cancel_task => cancel_task :CancelTask
        RunnerRequestType.open_exec   => open_exec   :OpenExecRunnerRequest

enum TaskControlKind:
    :u8
    submit
    list
    cancel
    prune_tasks
    get_task_log
    open_interactive
    client_hello

# ClientKind tags the kind of caller that opened a TaskControl session.
# Sent once right after handshake via TaskControlRequest{client_hello,...} so
# the server can log who connected (cli / tui / webui). Runners do not send
# this — they identify themselves via RunnerHello on a different channel.
enum ClientKind:
    :u8
    unspecified
    cli
    tui
    webui

format ClientHello:
    kind :ClientKind

enum ClientHelloStatus:
    :u8
    ok = "ok"

format ClientHelloResponse:
    status :ClientHelloStatus

format ListQuery:
    query :[..]u8 # currently opaque

format RunnerID:
    transport_len :u8
    transport :[transport_len]u8
    ip_addr_len :u8
    ip_addr_len == 4 || ip_addr_len == 16
    ip_addr :[ip_addr_len]u8
    port :u16
    unique_number :u16

enum TaskStatus:
    :u8
    Queued
    Running
    Succeeded
    Failed
    Cancelled

# TaskKind distinguishes how the task was requested.
#  - oneshot:     submitted via SubmitRequest, claude runs with -p prompt and exits
#  - interactive: opened via OpenInteractiveRequest, claude runs under a PTY
#                 spliced bytewise to the requesting client. Has empty prompt.
# Without this field the TUI has to infer the kind from len(prompt)==0,
# which is brittle (a freshly-stubbed TaskInfo from TaskStatusEvent would
# spuriously look interactive until the next List snapshot fills the prompt).
enum TaskKind:
    :u8
    oneshot
    interactive

enum RunnerStatus:
    :u8
    Offline
    Idle
    Busy

format RunnerInfo:
    id :RunnerID
    status :RunnerStatus
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    current_task :TaskID
    connected_at :u64  # unix nano
    last_seen :u64

format TaskInfo:
    id :TaskID
    status :TaskStatus
    kind :TaskKind
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    assigned_to :RunnerID
    worktree_dir_len :u16
    worktree_dir :[worktree_dir_len]u8
    created_at :u64
    started_at :u64
    ended_at :u64
    exit_code :i32
    prompt_len :u32
    prompt :[prompt_len]u8

format ListResult:
    runners_len :u16
    runners :[runners_len]RunnerInfo
    tasks_len :u16
    tasks :[tasks_len]TaskInfo

format SubmitRequest:
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    prompt_len :u32
    prompt :[prompt_len]u8

format SubmitResponse:
    task_id :TaskID

format PruneTasksRequest:
    before_ts :u64    # unix nano cutoff; terminal tasks with EndedAt < this are removed

format PruneTasksResponse:
    removed :u32

format GetTaskLogRequest:
    task_id :TaskID

format GetTaskLogResponse:
    found :u8         # 0 = no log file on server, 1 = found
    stream_id :u64    # 0 if !found; otherwise the unidirectional send-stream
                      # the server creates and writes the file content into
                      # (closed with EOF when complete). Client reads via
                      # trsf.Transport.GetReceiveStream.

format OpenInteractiveRequest:
    repo_path_len :u16
    repo_path :[repo_path_len]u8

enum OpenInteractiveStatus:
    :u8
    ok  = "ok"
    no_runner_for_repo = "no_runner_for_repo"
    runner_busy = "runner_busy"
    internal_error = "internal_error"

format OpenInteractiveResponse:
    status :OpenInteractiveStatus        
    task_id :TaskID    # populated when status == 0
    stream_id :u64     # populated when status == 0. Bidirectional stream the
                       # server opens toward the client; client looks it up via
                       # Transport.GetBidirectionalStream(id) and wraps it in
                       # exec.NewCommandExecutionStream. Server splices this
                       # bytewise to a separate bidi stream it has also opened
                       # toward the runner — the runner is told about its end
                       # via RunnerRequest{open_exec, task_id, stream_id} and
                       # feeds it to exec.ExecuteCommand for an interactive
                       # PTY claude session.

format TaskControlRequest:
    kind :TaskControlKind
    request_id :u32
    match kind:
        TaskControlKind.submit => submit :SubmitRequest
        TaskControlKind.list => list :ListQuery
        TaskControlKind.cancel => cancel :CancelTask
        TaskControlKind.prune_tasks => prune :PruneTasksRequest
        TaskControlKind.get_task_log => get_log :GetTaskLogRequest
        TaskControlKind.open_interactive => open_interactive :OpenInteractiveRequest
        TaskControlKind.client_hello => client_hello :ClientHello
        .. => error("Unexpected task")

format CancelStatus:
    status :u8

format TaskControlResponse:
    kind :TaskControlKind
    request_id :u32
    match kind:
        TaskControlKind.submit => submit :SubmitResponse
        TaskControlKind.list => list :ListResult
        TaskControlKind.cancel => cancel :CancelStatus
        TaskControlKind.prune_tasks => prune :PruneTasksResponse
        TaskControlKind.get_task_log => get_log :GetTaskLogResponse
        TaskControlKind.open_interactive => open_interactive :OpenInteractiveResponse
        TaskControlKind.client_hello => client_hello :ClientHelloResponse

# Pubsub event payloads
enum StatusEventKind:
    :u8
    task_queued
    task_assigned
    task_started
    task_ended
    runner_registered
    runner_offline

format TaskStatusEvent:
    kind :StatusEventKind
    task_id :TaskID
    ts :u64
    task_status :TaskStatus
    task_kind :TaskKind   # carried on every event (immutable for a task's lifetime)
                          # so a TUI receiving the very first event for a task
                          # can already render the right kind without waiting for
                          # the next List snapshot.
    exit_code :i32

format RunnerStatusEvent:
    kind :StatusEventKind
    runner_id :RunnerID
    ts :u64
    runner_status :RunnerStatus

