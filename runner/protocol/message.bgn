config.go.package = "protocol"

enum RunnerMessageType:
    :u8
    hello
    task_accepted
    task_started
    task_finished
    heartbeat
    establish_relay_response
    request_chained_relay
    remote_forward_conn
    remote_forward_bind_result

enum RunnerRequestType:
    :u8
    assign_task
    cancel_task
    open_exec
    runner_hello_response
    task_wake
    open_file_transfer
    list_files
    establish_relay
    chained_relay_response
    open_port_forward
    close_port_forward

# AllowedRoot is a single repository root path the runner is willing to accept tasks for.
format AllowedRoot:
    path_len :u16
    path :[path_len]u8

# ClaudeArg is one CLI argument forwarded verbatim to the spawned claude process.
# Per-arg length is u16 so individual flags / values can be up to 64KiB; in
# practice they are short (`--resume <uuid>`, `--add-dir <path>`).
format ClaudeArg:
    arg_len :u16
    arg :[arg_len]u8

# ClaudeArgs is a length-prefixed list of per-task extra CLI arguments.
# Inserted by clients (cli / tui / webui) at submit / open-interactive time;
# carried through SubmitRequest / OpenInteractiveRequest to AssignTask /
# OpenExecRunnerRequest so the runner can append them to the runner-global
# --claude-args baseline before exec'ing claude.
format ClaudeArgs:
    args_len :u16
    args :[args_len]ClaudeArg

# RunnerHello replaces the old single-repo shape.
# hostname is the runner's short hostname (for display / pinning).
# max_tasks is the concurrency limit this runner enforces (>=1; 0 -> server rejects).
# allowed_roots lists every repo root the runner can serve.
format RunnerHello:
    version :u8
    hostname_len :u8
    hostname :[hostname_len]u8
    max_tasks :u16
    allowed_roots_len :u8
    allowed_roots :[allowed_roots_len]AllowedRoot
    # basename of the agent binary the runner runs (--claude-bin): "claude" /
    # "gemini" / "codex" / "bash" / ... . Empty = unknown.
    agent_bin_len :u8
    agent_bin :[agent_bin_len]u8
    # whether the runner injects .claude/{settings.json,skills} for its tasks
    # (= the inbox hook AND this skill are present). False = peer follows none
    # of the skill conventions even if it is an agent CLI.
    skills_injected :u1
    reserved :u7

format TaskID:
    id :[16]u8

format AssignTask:
    # Server-initiated send-stream id; runner reads AssignTaskBody bytes
    # from this stream until EOF, then decodes. 0 = no stream available
    # (server too constrained to allocate); runner should NACK / drop.
    #
    # Streamed instead of inline so long prompts don't blow path MTU on
    # UDP transport — see
    # docs/superpowers/specs/2026-05-09-udp-dualstack-design.md §12.1.
    #
    # task_id is also kept inline so the runner can correlate the
    # incoming stream-id with a TaskID without round-tripping through
    # a partial AssignTaskBody read.
    task_id :TaskID
    stream_id :u64

# AssignTaskBody carries the actual assignment payload. Server encodes
# this and writes it to the trsf send-stream referenced by
# AssignTask.stream_id; runner decodes after reading the full stream.
format AssignTaskBody:
    auth_ticket :[16]u8
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    prompt_len :u32
    prompt :[prompt_len]u8
    extra_args :ClaudeArgs

format CancelTask:
    task_id :TaskID

# X11Forward carries the data needed to forward X11 to the client's local X
# server: the display number N (app sees DISPLAY=127.0.0.1:N -> TCP 6000+N) and
# the client's MIT-MAGIC-COOKIE-1 value (raw bytes, typically 16). Embedded
# conditionally in OpenInteractiveRequest and OpenExecRunnerRequest under
# `if x11_enabled == 1` so no bytes appear on the wire when X11 is off.
format X11Forward:
    display :u16
    cookie_len :u16
    cookie :[cookie_len]u8

format OpenExecRunnerRequest:
    task_id :TaskID
    auth_ticket :[16]u8
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    stream_id :u64    # bidi stream the server has just created toward this
                      # runner; runner looks it up via
                      # Transport.GetBidirectionalStream(id) and feeds it to
                      # exec.ExecuteCommand for an interactive PTY claude.
    extra_args :ClaudeArgs
    detachable :u1    # 1 = stream EOF → keep claude alive,
                      # 0 = stream EOF → SIGHUP ladder (legacy)
    x11_enabled :u1   # relayed from OpenInteractiveRequest.x11_enabled
    reserved :u6
    if x11_enabled == 1:
        x11 :X11Forward  # relayed verbatim from OpenInteractiveRequest.x11

format TaskWakeRequest:
    task_id :TaskID

# RunnerHelloResponse is sent by the server immediately after a successful
# RunnerHello. your_runner_id is the canonical RunnerID the server uses to
# key this runner in its registry / agentboard ticket store. The runner
# stores this and injects it as HARNESS_RUNNER_ID for spawned agents so the
# agent's bridge Hello (runner_id, task_id, ticket) matches what the server
# registered. The peer transport's ConnectionID is symmetric and surfaces
# the peer's ID, not the runner's own — so the runner cannot derive this
# value locally.
format RunnerHelloResponse:
    your_runner_id :RunnerID

format TaskAccepted:
    task_id :TaskID

format TaskStarted:
    task_id :TaskID
    worktree_dir_len :u16
    worktree_dir :[worktree_dir_len]u8

format TaskFinished:
    task_id :TaskID
    exit_code :i32
    error_message :[..]u8

format RunnerMessage:
    kind :RunnerMessageType
    match kind:
        RunnerMessageType.hello => hello :RunnerHello
        RunnerMessageType.task_accepted => task_accepted :TaskAccepted
        RunnerMessageType.task_started => task_started :TaskStarted
        RunnerMessageType.task_finished => task_finished :TaskFinished
        RunnerMessageType.heartbeat => ..
        RunnerMessageType.establish_relay_response => establish_relay_response :EstablishRelayResponse
        RunnerMessageType.request_chained_relay => request_chained_relay :RequestChainedRelay
        RunnerMessageType.remote_forward_conn => remote_forward_conn :RemoteForwardConn
        RunnerMessageType.remote_forward_bind_result => remote_forward_bind_result :RemoteForwardBindResult
        .. => error("Unexpected message")

format RunnerRequest:
    kind :RunnerRequestType
    match kind:
        RunnerRequestType.assign_task => assign_task :AssignTask
        RunnerRequestType.cancel_task => cancel_task :CancelTask
        RunnerRequestType.open_exec   => open_exec   :OpenExecRunnerRequest
        RunnerRequestType.runner_hello_response => runner_hello_response :RunnerHelloResponse
        RunnerRequestType.task_wake => task_wake :TaskWakeRequest
        RunnerRequestType.open_file_transfer => open_file_transfer :RunnerOpenFileTransferRequest
        RunnerRequestType.list_files         => list_files         :RunnerListFilesRequest
        RunnerRequestType.establish_relay    => establish_relay    :EstablishRelayRequest
        RunnerRequestType.chained_relay_response => chained_relay_response :ChainedRelayResponse
        RunnerRequestType.open_port_forward => open_port_forward :RunnerOpenPortForwardRequest
        RunnerRequestType.close_port_forward => close_port_forward :ClosePortForwardRequest

enum TaskControlKind:
    :u8
    submit
    list
    cancel
    prune_tasks
    get_task_log
    open_interactive
    client_hello
    attach_session
    open_file_transfer
    list_files
    dial_runner
    open_port_forward
    notify

# ClientKind tags the kind of caller that opened a TaskControl session.
# `agent` is an in-task harness-cli that proves its identity via agent_info;
# operator surfaces use cli/tui/webui and carry no agent_info.
enum ClientKind:
    :u8
    unspecified
    cli
    tui
    webui
    agent

# AgentInfo is the per-task agent credential, mirroring the (now-removed)
# agentboard AgentBridgeHello triple. Validated server-side via the agentboard
# Registry. hostname is length-prefixed (0 len = absent).
format AgentInfo:
    runner_id :RunnerID
    task_id :TaskID
    auth_ticket :[16]u8
    hostname_len :u8
    hostname :[hostname_len]u8

format ClientHello:
    kind :ClientKind
    if kind == ClientKind.agent:
        agent_info :AgentInfo

enum ClientHelloStatus:
    :u8
    ok = "ok"
    bad_ticket
    unknown_task
    runner_mismatch

format ClientHelloResponse:
    status :ClientHelloStatus

# admin → server: dial out to this runner endpoint and complete registration.
# Used in environments where ACL blocks runner→server outbound; server initiates
# the TCP/UDP connect instead.
format DialRunnerRequest:
    target :RunnerID
    via    :RunnerID

enum DialRunnerStatus:
    :u8
    ok             = "ok"
    dial_failed    = "dial_failed"
    psk_failed     = "psk_failed"
    hello_timeout  = "hello_timeout"
    invalid_target = "invalid_target"
    via_not_found      = "via_not_found"
    via_relay_failed   = "via_relay_failed"

format DialRunnerResponse:
    status :DialRunnerStatus

# server → proxy_runner: please prepare to relay between me and target at slot_id.
# Sent on the existing PSK-validated server↔proxy_runner registered conn.
format EstablishRelayRequest:
    target  :RunnerID
    slot_id :u16

enum EstablishRelayStatus:
    :u8
    ok                       = "ok"
    target_dial_failed       = "target_dial_failed"
    slot_collision           = "slot_collision"
    set_proxy_failed         = "set_proxy_failed"
    invalid_target           = "invalid_target"

format EstablishRelayResponse:
    status :EstablishRelayStatus

# runner → server: "before I install my local SetProxy for an agent Phase B
# ceremony, walk my chain on your side and make sure every upstream hop
# has the right SetProxy entry for slot_id."
format RequestChainedRelay:
    slot_id :u16

enum ChainedRelayStatus:
    :u8
    ok                  = "ok"
    direct              = "direct"             # no chain — runner is registered direct
    slot_collision      = "slot_collision"
    hop_setup_failed    = "hop_setup_failed"
    chain_unwalkable    = "chain_unwalkable"
    another_in_flight   = "another_in_flight"

format ChainedRelayResponse:
    status :ChainedRelayStatus

# Phase B: agent ↔ runner negotiated-proxy ceremony.
# Agent sends ProxyRequest as the first app message after peer.Dial-ing the
# runner; runner replies with ProxyEstablishResponse. See spec
# docs/superpowers/specs/2026-05-22-server-mode-runner-reverse-dial-design.md Phase B.

format ProxyRequest:
    task_id :TaskID

enum ProxyEstablishStatus:
    :u8
    ok                   = "ok"
    id_collision         = "id_collision"
    server_not_connected = "server_not_connected"
    unknown_task         = "unknown_task"
    internal_error       = "internal_error"     # runner-side SetProxy or other internal failure; agent should NOT retry

format ProxyEstablishResponse:
    status :ProxyEstablishStatus

enum ProxyControlKind:
    :u8
    request
    establish_response

format ProxyControl:
    kind :ProxyControlKind
    match kind:
        ProxyControlKind.request              => request              :ProxyRequest
        ProxyControlKind.establish_response   => establish_response   :ProxyEstablishResponse

# Phase B: server → runner marker sent immediately after server-side
# DoECDHHandshake completes (reverse-dial path). Lets the runner's accept
# handler discriminate "server conn" vs "agent conn" without timing heuristics.
# version is reserved for forward-compatible feature negotiation; the runner
# logs unknown versions and proceeds.
format DialGreeting:
    version :u8

format ListQuery:
    query :[..]u8 # currently opaque

format RunnerID:
    transport_len :u8
    transport :[transport_len]u8
    ip_addr_len :u8
    ip_addr_len == 0 || ip_addr_len == 4 || ip_addr_len == 16
    ip_addr :[ip_addr_len]u8
    port :u16
    unique_number :u16

enum TaskStatus:
    :u8
    Queued
    Running
    Succeeded
    Failed
    Cancelled
    Detached

# TaskKind distinguishes how the task was requested.
#  - oneshot:     submitted via SubmitRequest, claude runs with -p prompt and exits
#  - interactive: opened via OpenInteractiveRequest, claude runs under a PTY
#                 spliced bytewise to the requesting client. Has empty prompt.
# Without this field the TUI has to infer the kind from len(prompt)==0,
# which is brittle (a freshly-stubbed TaskInfo from TaskStatusEvent would
# spuriously look interactive until the next List snapshot fills the prompt).
enum TaskKind:
    :u8
    oneshot
    interactive

enum RunnerStatus:
    :u8
    Offline
    Idle
    Busy

# ActiveTaskRef records a currently-running task assigned to a runner.
format ActiveTaskRef:
    task_id :TaskID
    repo_path_len :u16
    repo_path :[repo_path_len]u8

# RunnerInfo replaces the old single-repo shape with multi-root and active-tasks.
format RunnerInfo:
    id :RunnerID
    hostname_len :u8
    hostname :[hostname_len]u8
    status :RunnerStatus
    max_tasks :u16
    allowed_roots_len :u8
    allowed_roots :[allowed_roots_len]AllowedRoot
    active_tasks_len :u16
    active_tasks :[active_tasks_len]ActiveTaskRef
    connected_at :u64  # unix nano
    last_seen :u64
    # peer identity (mirrors RunnerHello): agent binary basename + whether the
    # runner injects .claude/{settings.json,skills}. Echoed by the server.
    agent_bin_len :u8
    agent_bin :[agent_bin_len]u8
    skills_injected :u1
    reserved :u7

format TaskInfo:
    id :TaskID
    status :TaskStatus
    kind :TaskKind
    origin_kind :ClientKind   # which kind of client submitted this task (cli / tui / webui).
                              # Set by the server from the connection's last ClientHello.
                              # Stays Unspecified for tasks created before any hello.
    resumed_by_kind :ClientKind  # kind of the connection that performed the
                              # LATEST resume; Unspecified until first resumed.
                              # origin_kind stays the original creator.
    creator_task_id :TaskID   # task id of the AGENT principal that created this
                              # task (kind=agent connection). All-zero for
                              # operator-created tasks. Set at Create; unchanged
                              # on resume. Single parent link.
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    assigned_to :RunnerID
    worktree_dir_len :u16
    worktree_dir :[worktree_dir_len]u8
    created_at :u64
    started_at :u64
    ended_at :u64
    exit_code :i32
    prompt_len :u32
    prompt :[prompt_len]u8
    error_len :u32
    error_message :[error_len]u8
    detachable :u1        # immutable, set at OpenInteractive time
    is_attached :u1       # client tuiStream is currently spliced
    reserved :u6
    ring_buffer_bytes :u64    # current bytes buffered (0 for non-detachable)

format ListResult:
    # Server-initiated send-stream id; client reads ListResultBody bytes
    # from this stream until EOF, then decodes. 0 = no stream available
    # (e.g. server too constrained to allocate); client treats as error.
    #
    # Streamed instead of inline so the response fits comfortably in any
    # path MTU on UDP transport — see
    # docs/superpowers/specs/2026-05-09-udp-dualstack-design.md §12.1.
    stream_id :u64

# ListResultBody carries the actual runners + tasks payload. Server
# encodes this and writes it to the trsf send-stream referenced by
# ListResult.stream_id; client decodes after reading the full stream.
format ListResultBody:
    runners_len :u16
    runners :[runners_len]RunnerInfo
    tasks_len :u16
    tasks :[tasks_len]TaskInfo

# RunnerSelectorKind tags which selector variant is active.
enum RunnerSelectorKind:
    :u8
    any          # no preference; server picks
    by_runner_id # pin to a specific RunnerID
    by_hostname  # pin to a runner with a matching hostname
    by_ip        # pin to a runner at a specific IP address

# Hostname selector: the hostname string the runner advertised in RunnerHello.
format Hostname:
    name_len :u8
    name :[name_len]u8

# IPAddr selector: raw IPv4 (4 bytes) or IPv6 (16 bytes).
format IPAddr:
    addr_len :u8
    addr_len == 4 || addr_len == 16
    addr :[addr_len]u8

# RunnerSelector is the tagged union embedded in SubmitRequest and
# OpenInteractiveRequest that lets a client pin a task to a specific runner.
format RunnerSelector:
    kind :RunnerSelectorKind
    match kind:
        RunnerSelectorKind.any          => ..
        RunnerSelectorKind.by_runner_id => runner_id :RunnerID
        RunnerSelectorKind.by_hostname  => hostname  :Hostname
        RunnerSelectorKind.by_ip        => ip_addr   :IPAddr

format SubmitRequest:
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    selector :RunnerSelector
    prompt_len :u32
    prompt :[prompt_len]u8
    extra_args :ClaudeArgs
    # resume_task_id, when all-zero, means "create a new task". When non-zero,
    # the server looks up that TaskID, validates it is in a terminal state
    # (Succeeded / Failed / Cancelled), and re-queues it under the SAME id so
    # the runner re-attaches its worktree to the retained `harness/<id>` branch
    # — claude's project key (~/.claude/projects/<cwd-hash>/) therefore lines
    # up with the previous run, which is what makes `--claude-arg --resume
    # <session-uuid>` actually work after the 2.1.123 picker regression.
    resume_task_id :TaskID

# SubmitStatus indicates the outcome of a SubmitRequest.
enum SubmitStatus:
    :u8
    ok                  = "ok"
    no_runner           = "no_runner"
    ambiguous_runner    = "ambiguous_runner"
    pinned_not_found    = "pinned_not_found"
    internal_error      = "internal_error"
    # resume_not_found / resume_not_terminal are returned when resume_task_id
    # is set but the target either doesn't exist or is still active (Queued /
    # Running / already mid-resume). Concurrent resume attempts on the same
    # ID land here — the second caller sees resume_not_terminal because the
    # first transitioned the status back to Queued under TaskStore.mu.
    resume_not_found    = "resume_not_found"
    resume_not_terminal = "resume_not_terminal"

# SubmitResponse replaces the old bare task_id with a status + optional error.
format SubmitResponse:
    status :SubmitStatus
    task_id :TaskID        # zero when status != ok
    error_msg_len :u16
    error_msg :[error_msg_len]u8

format PruneTasksRequest:
    before_ts :u64    # unix nano cutoff; terminal tasks with EndedAt < this are removed
                      # ignored when task_ids_len > 0
    task_ids_len :u16
    task_ids :[task_ids_len]TaskID    # when non-empty: prune only these ids, ignoring before_ts
    force :u8                          # 1 = also prune ids whose tasks are still active (Queued/Running/Detached)

format PruneTasksResponse:
    removed :u32
    skipped_active :u32    # id-mode only: tasks not pruned because still active and force=0
    skipped_missing :u32   # id-mode only: ids that were not present in the server's task store

format GetTaskLogRequest:
    task_id :TaskID

format GetTaskLogResponse:
    found :u8         # 0 = no log file on server, 1 = found
    stream_id :u64    # 0 if !found; otherwise the unidirectional send-stream
                      # the server creates and writes the file content into
                      # (closed with EOF when complete). Client reads via
                      # trsf.Transport.GetReceiveStream.

format OpenInteractiveRequest:
    repo_path_len :u16
    repo_path :[repo_path_len]u8
    selector :RunnerSelector
    extra_args :ClaudeArgs
    # See SubmitRequest.resume_task_id — same semantics, applied to the
    # interactive path (PTY claude with empty prompt).
    detachable :u1    # 1 = session new (detach on disconnect),
                      # 0 = legacy interactive (kill on disconnect)
    x11_enabled :u1   # 1 = client requested X11 forwarding; gates the
                      # conditional block below. Incompatible with detach (no
                      # client process to host the tunnel).
    reserved :u6
    resume_task_id :TaskID
    # X11 block is on the wire ONLY when x11_enabled == 1 (no invisible bytes
    # when disabled).
    if x11_enabled == 1:
        x11 :X11Forward

enum OpenInteractiveStatus:
    :u8
    ok  = "ok"
    no_runner_for_repo  = "no_runner_for_repo"
    runner_busy         = "runner_busy"
    ambiguous_runner    = "ambiguous_runner"
    pinned_not_found    = "pinned_not_found"
    internal_error      = "internal_error"
    # See SubmitStatus — same resume semantics for the interactive path.
    resume_not_found    = "resume_not_found"
    resume_not_terminal = "resume_not_terminal"

format OpenInteractiveResponse:
    status :OpenInteractiveStatus
    task_id :TaskID    # populated when status == 0
    stream_id :u64     # populated when status == 0. Bidirectional stream the
                       # server opens toward the client; client looks it up via
                       # Transport.GetBidirectionalStream(id) and wraps it in
                       # exec.NewCommandExecutionStream. Server splices this
                       # bytewise to a separate bidi stream it has also opened
                       # toward the runner — the runner is told about its end
                       # via RunnerRequest{open_exec, task_id, stream_id} and
                       # feeds it to exec.ExecuteCommand for an interactive
                       # PTY claude session.

enum AttachMode:
    :u8
    control = "control"   # default (ordinal 0): takeover-writer behavior
    view    = "view"      # read-only observer; no input, no takeover

format AttachSessionRequest:
    task_id :TaskID
    mode :AttachMode

enum AttachSessionStatus:
    :u8
    ok                  = "ok"
    not_found           = "not_found"
    not_interactive     = "not_interactive"
    not_detachable      = "not_detachable"
    already_terminal    = "already_terminal"
    runner_unreachable  = "runner_unreachable"
    internal_error      = "internal_error"

format AttachSessionResponse:
    status :AttachSessionStatus
    stream_id :u64
    replay_bytes :u64

format TaskControlRequest:
    kind :TaskControlKind
    request_id :u32
    match kind:
        TaskControlKind.submit => submit :SubmitRequest
        TaskControlKind.list => list :ListQuery
        TaskControlKind.cancel => cancel :CancelTask
        TaskControlKind.prune_tasks => prune :PruneTasksRequest
        TaskControlKind.get_task_log => get_log :GetTaskLogRequest
        TaskControlKind.open_interactive => open_interactive :OpenInteractiveRequest
        TaskControlKind.client_hello => client_hello :ClientHello
        TaskControlKind.attach_session => attach :AttachSessionRequest
        TaskControlKind.open_file_transfer => open_file_transfer :OpenFileTransferRequest
        TaskControlKind.list_files         => list_files         :ListFilesRequest
        TaskControlKind.dial_runner        => dial_runner        :DialRunnerRequest
        TaskControlKind.open_port_forward  => open_port_forward  :OpenPortForwardRequest
        TaskControlKind.notify              => notify             :NotifyRequest
        .. => error("Unexpected task")

format CancelStatus:
    status :u8

format TaskControlResponse:
    kind :TaskControlKind
    request_id :u32
    match kind:
        TaskControlKind.submit => submit :SubmitResponse
        TaskControlKind.list => list :ListResult
        TaskControlKind.cancel => cancel :CancelStatus
        TaskControlKind.prune_tasks => prune :PruneTasksResponse
        TaskControlKind.get_task_log => get_log :GetTaskLogResponse
        TaskControlKind.open_interactive => open_interactive :OpenInteractiveResponse
        TaskControlKind.client_hello => client_hello :ClientHelloResponse
        TaskControlKind.attach_session => attach :AttachSessionResponse
        TaskControlKind.open_file_transfer => open_file_transfer :OpenFileTransferResponse
        TaskControlKind.list_files         => list_files         :ListFilesResponse
        TaskControlKind.dial_runner        => dial_runner        :DialRunnerResponse
        TaskControlKind.open_port_forward  => open_port_forward  :OpenPortForwardResponse
        TaskControlKind.notify              => notify             :NotifyResponse

enum NotifyLevel:
    :u8
    info = "info"
    warn = "warn"
    error = "error"

enum NotifyOrigin:
    :u8
    worker = "worker"
    external = "external"

enum NotifyStatus:
    :u8
    accepted
    no_hook
    spawn_failed

# Worker identity as text (not the typed RunnerID): a zero-value RunnerID trips
# the IpAddrLen hard assertion and panics the encoder. The hook only needs strings.
format WorkerInfo:
    task_id_len   :u16
    task_id       :[task_id_len]u8
    runner_id_len :u16
    runner_id     :[runner_id_len]u8
    repo_len      :u16
    repo          :[repo_len]u8
    hostname_len  :u16
    hostname      :[hostname_len]u8

format NotifyRequest:
    level  :NotifyLevel
    origin :NotifyOrigin
    if origin == NotifyOrigin.worker:
        worker :WorkerInfo
    title_len :u16
    title     :[title_len]u8
    text_len  :u16
    text      :[text_len]u8

format NotifyResponse:
    status :NotifyStatus

format NotifyEvent:
    ts          :u64
    client_kind :ClientKind
    level  :NotifyLevel
    origin :NotifyOrigin
    if origin == NotifyOrigin.worker:
        worker :WorkerInfo
    title_len :u16
    title     :[title_len]u8
    text_len  :u16
    text      :[text_len]u8

# Pubsub event payloads
enum StatusEventKind:
    :u8
    task_queued
    task_assigned
    task_started
    task_ended
    runner_registered
    runner_offline
    task_pruned       # appended (keeps existing ordinals stable): the server
                      # forgot a terminal task; clients remove its row. Carries
                      # task_id + kind only — task_status/task_kind are unset
                      # because the TaskStore entry is already gone.

format TaskStatusEvent:
    kind :StatusEventKind
    task_id :TaskID
    ts :u64
    task_status :TaskStatus
    task_kind :TaskKind   # carried on every event (immutable for a task's lifetime)
                          # so a TUI receiving the very first event for a task
                          # can already render the right kind without waiting for
                          # the next List snapshot.
    exit_code :i32

format RunnerStatusEvent:
    kind :StatusEventKind
    runner_id :RunnerID
    ts :u64
    runner_status :RunnerStatus

# === File transfer (client ↔ runner; see specs/2026-05-10-file-transfer-design.md) ===

enum FileTransferDirection:
    :u8
    push
    pull
    delete       # remove a file from the worktree (rejects directories).
    dir_push     # client → runner; body is a tar stream of the source dir.
    dir_pull     # runner → client; body is a tar stream of the source dir.
    dir_delete   # remove a directory from the worktree. force=0 → empty
                 # dir only (fails on non-empty); force=1 → recursive
                 # (os.RemoveAll). Rejects regular files (use `delete`).

enum FileTransferStatus:
    :u8
    ok             = "ok"
    path_invalid   = "path_invalid"
    not_found      = "not_found"
    already_exists = "already_exists"
    io_error       = "io_error"
    canceled       = "canceled"
    is_directory   = "is_directory"   # delete only: rel_path resolved to a directory.
    not_a_directory = "not_a_directory"  # dir_push: dest exists but is a regular file. dir_pull / dir_delete: source is a regular file (not a directory).
    not_empty       = "not_empty"     # dir_delete: target directory is non-empty and force=0 (recursive not requested).

format FileTransferAck:
    status      :FileTransferStatus
    actual_size :u64

# FileTransferAck is fixed-size; expose its on-the-wire byte length so
# readers can pre-allocate and consume exactly that many bytes from the
# stream without an in-band length prefix.
FileTransferAckSize ::= sizeof(FileTransferAck)

format FileEntry:
    name_len :u16
    name     :[name_len]u8
    size     :u64
    mode     :u32
    is_dir   :u1
    reserved :u7

format FileListing:
    count   :u32
    entries :[count]FileEntry

format OpenFileTransferRequest:
    task_id       :TaskID
    direction     :FileTransferDirection
    rel_path_len  :u16
    rel_path      :[rel_path_len]u8
    expected_size :u64
    force         :u1
    reserved      :u7

enum OpenFileTransferStatus:
    :u8
    ok             = "ok"
    no_such_task   = "no_such_task"
    runner_offline = "runner_offline"
    internal_error = "internal_error"

format OpenFileTransferResponse:
    status    :OpenFileTransferStatus
    stream_id :u64

format ListFilesRequest:
    task_id      :TaskID
    rel_path_len :u16
    rel_path     :[rel_path_len]u8

enum ListFilesStatus:
    :u8
    ok              = "ok"
    no_such_task    = "no_such_task"
    runner_offline  = "runner_offline"
    path_invalid    = "path_invalid"
    not_found       = "not_found"
    not_a_directory = "not_a_directory"
    io_error        = "io_error"
    internal_error  = "internal_error"

format ListFilesResponse:
    status    :ListFilesStatus
    stream_id :u64

format RunnerOpenFileTransferRequest:
    task_id       :TaskID
    stream_id     :u64
    direction     :FileTransferDirection
    rel_path_len  :u16
    rel_path      :[rel_path_len]u8
    expected_size :u64
    force         :u1
    reserved      :u7

format RunnerListFilesRequest:
    task_id      :TaskID
    stream_id    :u64
    rel_path_len :u16
    rel_path     :[rel_path_len]u8

# === Port forwarding (client ↔ runner; see specs/2026-06-02-port-forward-design.md) ===

enum PortForwardDirection:
    :u8
    local    # client listens, runner dials remote_host:remote_port (SSH -L).
    remote   # runner listens on bind_addr:bind_port, client dials remote_host:remote_port (SSH -R).

enum OpenPortForwardStatus:
    :u8
    ok             = "ok"
    no_such_task   = "no_such_task"
    runner_offline = "runner_offline"
    internal_error = "internal_error"
    bind_failed    = "bind_failed"

# OpenPortForwardRequest: remote_host/remote_port are the dial target (runner
# dials it for local; client dials it for remote). bind_addr/bind_port are the
# runner-side listener for remote forwards (unused for local).
format OpenPortForwardRequest:
    task_id           :TaskID
    direction         :PortForwardDirection
    remote_host_len   :u16
    remote_host       :[remote_host_len]u8
    remote_port       :u16
    bind_addr_len     :u16
    bind_addr         :[bind_addr_len]u8
    bind_port         :u16

# OpenPortForwardResponse: for local, stream_id is the data stream. For remote,
# stream_id is the server-created persistent control stream (the client picks it
# up by id and reads RemoteForwardConnNotify records off it); forward_id is the
# registration handle.
format OpenPortForwardResponse:
    status     :OpenPortForwardStatus
    stream_id  :u64
    forward_id :u64

format RunnerOpenPortForwardRequest:
    task_id           :TaskID
    stream_id         :u64
    direction         :PortForwardDirection
    remote_host_len   :u16
    remote_host       :[remote_host_len]u8
    remote_port       :u16
    bind_addr_len     :u16
    bind_addr         :[bind_addr_len]u8
    bind_port         :u16
    forward_id        :u64

# ClosePortForwardRequest tells the runner to stop a remote-forward listener.
format ClosePortForwardRequest:
    forward_id :u64

# RemoteForwardConn (runner -> server): a connection arrived on a remote-forward
# listener; stream_id is the runner-created stream for it.
format RemoteForwardConn:
    forward_id :u64
    stream_id  :u64

# RemoteForwardConnNotify (server -> client, on the control stream): dial your
# local target and pick up the data stream by stream_id.
format RemoteForwardConnNotify:
    stream_id :u64

# RemoteForwardBindResult (runner -> server): result of trying to open the
# remote-forward listener. ok=1 if bound, 0 if net.Listen failed. The server
# blocks the registration response until this arrives, so the client learns
# success/failure instead of a silent no-op.
format RemoteForwardBindResult:
    forward_id :u64
    ok         :u1
    reserved   :u7
