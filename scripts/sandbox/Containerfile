# Sandbox image for running Claude Code confined in a ROOTLESS podman container.
#
# Built to be run as `podman run --userns=keep-id` (see claude-in-podman.sh):
# keep-id maps the invoking host user (e.g. uid 1000) into the container
# unchanged, so claude runs as a NON-root user — which both satisfies its
# "refuse --dangerously-skip-permissions as root" rule AND keeps the agent's
# worktree edits owned by the host user on disk.
#
# No USER line and no app account: the runtime uid is supplied by keep-id at
# `podman run` time, and the wrapper sets HOME + cwd. claude installs to
# /usr/local/bin so any uid can execute it.

ARG NODE_TAG=22-bookworm-slim
FROM node:${NODE_TAG}

# Pin to a specific Claude Code release for reproducible images, or override:
#   podman build --build-arg CLAUDE_VERSION=2.1.169 ...
ARG CLAUDE_VERSION=latest

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      git ripgrep ca-certificates curl less \
      python3 python3-pip python3-venv \
      iptables ipset iproute2 dnsutils aggregate jq gosu \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g "@anthropic-ai/claude-code@${CLAUDE_VERSION}" \
 && npm cache clean --force \
 && claude --version \
 && python3 --version

# Egress-firewall kit (used only when the wrapper passes --firewall; see
# entrypoint.sh / init-firewall.sh). Harmless dead weight otherwise.
COPY init-firewall.sh       /usr/local/bin/sandbox-init-firewall.sh
COPY init-firewall-proxy.sh /usr/local/bin/sandbox-init-firewall-proxy.sh
COPY connect-proxy.py       /usr/local/bin/sandbox-connect-proxy.py
COPY claude-launch.sh       /usr/local/bin/sandbox-claude-launch.sh
COPY entrypoint.sh          /usr/local/bin/sandbox-entrypoint.sh
RUN chmod +x /usr/local/bin/sandbox-init-firewall.sh \
             /usr/local/bin/sandbox-init-firewall-proxy.sh \
             /usr/local/bin/sandbox-connect-proxy.py \
             /usr/local/bin/sandbox-claude-launch.sh \
             /usr/local/bin/sandbox-entrypoint.sh

# Token-auth runs from the image's own home (/home/node) with an ephemeral
# ~/.claude every run, so interactive claude would re-show the first-run
# onboarding (theme/welcome) each time. Pre-seed onboarding-complete so it starts
# straight at the prompt; auth still comes from CLAUDE_CODE_OAUTH_TOKEN.
RUN printf '{"hasCompletedOnboarding": true, "theme": "dark"}\n' > /home/node/.claude.json \
 && chown node:node /home/node/.claude.json
