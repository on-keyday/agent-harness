config.go.package = "protocol"
enum MessageKind:
    :u8
    JOIN
    LEAVE

format PubSubRequest:
    config.go.union = "noheap"
    kind :MessageKind
    if kind == MessageKind.JOIN:
        nick_name_len :u8
        nick_name :[nick_name_len]u8
    topic :[..]u8

enum Status:
    :u8 
    ok 
    already_subscribed
    unknown_message
    unknown_topic

format PubSubResponse:
    status :Status 
    stream_id :u64

